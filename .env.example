# ==============================================================================
# TradeNexa - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and populate with your local values.
# Do NOT commit the '.env' file containing real secrets to the repository!

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# Environment to run the app in ('development', 'production', 'test')
NODE_ENV=development
# Port number the server will listen on
PORT=3000
# Name of the application (used in logging and notifications)
APP_NAME=TradeNexa
# Fully qualified URL where the application is hosted locally
APP_URL=http://localhost:3000
# Maximum upload size for images in bytes (default: 5MB)
UPLOAD_MAX_FILE_SIZE=5242880
# Maximum upload size for videos in bytes (default: 50MB)
UPLOAD_MAX_VIDEO_FILE_SIZE=52428800

# ------------------------------------------------------------------------------
# Railway S3 Bucket (object storage for all uploads)
# ------------------------------------------------------------------------------
# Railway injects these when you link a Bucket service to your app:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto
#
# Optional: direct public bucket URL — leave empty to serve via APP_URL/media/ proxy
AWS_S3_PUBLIC_URL=
#
# Optional: prefix folder inside the bucket (e.g. tradenexa)
AWS_S3_PREFIX=tradenexa

# ------------------------------------------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------------------------------------------
# Database server host address
DB_HOST=localhost
# Database port number (MySQL default is 3306)
DB_PORT=3306
# Database username
DB_USER=root
# Database password
DB_PASSWORD=
# Database name to connect to
DB_NAME=tradenexa

# ------------------------------------------------------------------------------
# Security & JWT Configurations
# ------------------------------------------------------------------------------
# Strong random secret key used to sign Access tokens (e.g. generate via: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
# Strong random secret key used to sign Refresh tokens
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Expiries formatted in milliseconds orzeit format (e.g. '15m', '7d', '10m', '12h')
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REGISTRATION_EXPIRY=10m

# Cryptography salt rounds (higher is more secure but slower, default: 12)
BCRYPT_SALT_ROUNDS=12

# ------------------------------------------------------------------------------
# Firebase Admin SDK & Auth Configurations
# ------------------------------------------------------------------------------
# Firebase Project ID (found under project settings in Firebase Console)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Firebase Client Email associated with your service account
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# Firebase Private Key (must contain the entire block including BEGIN/END header, with literal newlines '\n' escaped or directly formatted)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
# Firebase Web API Key (required for client-side authentication triggers or OTP verification API)
FIREBASE_API_KEY=your-firebase-web-api-key

# ------------------------------------------------------------------------------
# Rate Limiting & CORS Configurations
# ------------------------------------------------------------------------------
# Permitted origins for CORS (comma-separated). Use * to allow all origins.
# Dev default allows localhost:3000 and localhost:5173 (Vite) when unset.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# Window size in milliseconds for rate limiting (e.g., 900000 ms is 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests allowed per IP address within the window
RATE_LIMIT_MAX=100

# ------------------------------------------------------------------------------
# Logger Configurations
# ------------------------------------------------------------------------------
# Log level to capture ('error', 'warn', 'info', 'http', 'verbose', 'debug', 'silly')
LOG_LEVEL=info
# Directory for log files
LOG_DIR=src/logs
